<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Tree View for Service System -->
        <record id="service_system_view_tree" model="ir.ui.view">
            <field name="name">odoo_product_digital.service_system.tree</field>
            <field name="model">odoo_product_digital.service_system</field>
            <field name="arch" type="xml">
                <tree string="Service Systems">
                    <field name="name"/>
                    <field name="people"/>
                    <field name="technology"/>
                    <field name="money"/>
                    <field name="information"/>
                    <field name="competencies"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Service System -->
        <record id="service_system_view_form" model="ir.ui.view">
            <field name="name">odoo_product_digital.service_system.form</field>
            <field name="model">odoo_product_digital.service_system</field>
            <field name="arch" type="xml">
                <form string="Service System">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="people"/>
                            <field name="technology"/>
                            <field name="money"/>
                            <field name="information"/>
                            <field name="competencies"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
