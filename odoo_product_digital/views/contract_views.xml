<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Tree View for Contract -->
        <record id="contract_view_tree" model="ir.ui.view">
            <field name="name">odoo_product_digital.contract.tree</field>
            <field name="model">odoo_product_digital.contract</field>
            <field name="arch" type="xml">
                <tree string="Contracts">
                    <field name="name"/>
                    <field name="price"/>
                    <field name="sla"/>
                    <field name="interaction_rules"/>
                    <field name="governance"/>
                    <field name="security"/>
                    <field name="expected_outcomes"/>
                    <field name="scoped_resources"/>
                    <field name="service_offer_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Contract -->
        <record id="contract_view_form" model="ir.ui.view">
            <field name="name">odoo_product_digital.contract.form</field>
            <field name="model">odoo_product_digital.contract</field>
            <field name="arch" type="xml">
                <form string="Contract">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="sla"/>
                            <field name="interaction_rules"/>
                            <field name="governance"/>
                            <field name="security"/>
                            <field name="expected_outcomes"/>
                            <field name="scoped_resources"/>
                            <field name="service_offer_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
