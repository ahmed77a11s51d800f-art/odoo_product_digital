<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Tree View for Product Instance -->
        <record id="product_instance_view_tree" model="ir.ui.view">
            <field name="name">odoo_product_digital.product_instance.tree</field>
            <field name="model">odoo_product_digital.product_instance</field>
            <field name="arch" type="xml">
                <tree string="Product Instances">
                    <field name="name"/>
                    <field name="type"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Product Instance -->
        <record id="product_instance_view_form" model="ir.ui.view">
            <field name="name">odoo_product_digital.product_instance.form</field>
            <field name="model">odoo_product_digital.product_instance</field>
            <field name="arch" type="xml">
                <form string="Product Instance">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>

